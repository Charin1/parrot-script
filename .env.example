# Whisper
WHISPER_MODEL=medium.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8_float32
WHISPER_BEAM_SIZE=5

# Audio
AUDIO_DEVICE_INDEX=0
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=5
AUDIO_VAD_AGGRESSIVENESS=2

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT=120

# Database
DB_PATH=./data/meetings.db
CHROMA_PATH=./data/chroma
ANONYMIZED_TELEMETRY=False

# API
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
API_WORKERS=1
API_LOG_LEVEL=info
API_TOKEN=change-me-local-token
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173","http://127.0.0.1:8501","http://localhost:8501"]

# Speaker
MAX_SPEAKERS=8
SPEAKER_CLUSTER_THRESHOLD=0.85
EMBEDDING_WINDOW_SIZE=50
SPEAKER_SEGMENT_PADDING_SECONDS=0.35
SPEAKER_MIN_SEGMENT_SECONDS=1.2
SPEAKER_SIMILARITY_MARGIN=0.08
SPEAKER_TEMPORAL_HOLD_SECONDS=1.25
SPEAKER_MIN_STABLE_SEGMENTS=2
SPEAKER_MIN_STABLE_SECONDS=2.0
SPEAKER_REPORTING_MERGE_THRESHOLD=0.93

# Summarization
SUMMARY_CHUNK_SIZE=3000
SUMMARY_MAX_TOKENS=1000
